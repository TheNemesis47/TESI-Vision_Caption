lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Application logs
logs/
*.log

# Unit test / coverage reports
htmlcov/
.tox/
.nosexy
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.pytest_cache/
.pytest/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Sphinx documentation
doc/_build/

# PyBuilder
.pybuilder/
target/

# Jupyter Notebook
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# pyenv
#   For a library or package, you might want to share your Python version
#   with the community by uncommenting this.
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in case of collaboration, if delegates have different platforms,
#   you may want to keep Pipfile.lock in git.
#Pipfile.lock

# poetry
#   Similar to Pipenv, Poetry uses poetry.lock and pyproject.toml to manage dependencies.
#   It is recommended to commit poetry.lock.
#poetry.lock

# pdm
#   Similar to Poetry, PDM uses pdm.lock to manage dependencies
#pdm.lock

# venv
#   Useful for virtual environments
.venv/
venv/
ENV/
env/

# IDEs
.idea/
.vscode/
*.swp
*.swo

# Project specific
graphify-out/
.agents/
.antigravitycli/

# Secrets / credentials (NEVER commit)
.env
.env.*
!.env.example
*.pem
cert.pem
key.pem

# Model weights / checkpoints (too large for git)
models/
*.pth
*.pt
